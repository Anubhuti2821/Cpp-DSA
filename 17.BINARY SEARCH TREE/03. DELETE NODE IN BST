/*
Problem: Delete Node in a BST

Given the root of a Binary Search Tree (BST) and a key,
delete the node with the given key and return the updated BST.

Approach:
1. Search for the node to delete.
2. Handle three cases:
   - Node has no child.
   - Node has one child.
   - Node has two children:
     - Find the inorder successor (smallest node in right subtree).
     - Copy its value to the current node.
     - Delete the inorder successor from the right subtree.
*/

class Solution {
public:
    TreeNode* inorderSuccessor(TreeNode* root) {
        while (root != NULL && root->left != NULL) {
            root = root->left;
        }
        return root;
    }

    TreeNode* deleteNode(TreeNode* root, int key) {
        if (root == NULL) {
            return NULL;
        }

        if (key > root->val) {
            root->right = deleteNode(root->right, key);
        }
        else if (key < root->val) {
            root->left = deleteNode(root->left, key);
        }
        else {

            // Case 1: No child
            if (root->left == NULL && root->right == NULL) {
                delete root;
                return NULL;
            }

            // Case 2: Only right child
            else if (root->left == NULL) {
                TreeNode* temp = root->right;
                delete root;
                return temp;
            }

            // Case 3: Only left child
            else if (root->right == NULL) {
                TreeNode* temp = root->left;
                delete root;
                return temp;
            }

            // Case 4: Two children
            else {
                TreeNode* IS = inorderSuccessor(root->right);
                root->val = IS->val;
                root->right = deleteNode(root->right, IS->val);
            }
        }

        return root;
    }
};

/*
Time Complexity: O(h)
- h = height of the BST.
- Best/Average: O(log n)
- Worst: O(n) for a skewed BST.

Space Complexity: O(h)
- Due to recursive call stack.
*/

/*
Possible Optimization:
This recursive solution is optimal for BST deletion.
An iterative implementation can reduce recursion overhead,
but the time complexity remains O(h).
*/
