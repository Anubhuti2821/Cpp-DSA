/*
Problem: Search in a Binary Search Tree

Given the root of a Binary Search Tree (BST) and an integer val,
return the subtree rooted with the node that has the given value.
If the node does not exist, return NULL.

Approach:
- If the current node is NULL, the value doesn't exist.
- If the current node's value is equal to val, return the current node.
- If val is greater than the current node's value, search in the right subtree.
- Otherwise, search in the left subtree.
*/

class Solution {
public:
    TreeNode* searchBST(TreeNode* root, int val) {

        if (root == NULL) {
            return NULL;
        }

        if (root->val == val) {
            return root;
        }

        if (root->val < val) {
            return searchBST(root->right, val);
        }

        return searchBST(root->left, val);
    }
};

/*
Time Complexity: O(h)
- h = height of the BST.
- Best/Average: O(log n)
- Worst: O(n) (skewed tree)

Space Complexity: O(h)
- Recursive call stack.
*/

