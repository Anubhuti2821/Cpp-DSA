/*
Problem: Flatten Binary Tree to Linked List

Approach:
- Use Reverse Preorder Traversal (Right -> Left -> Root).
- Maintain a pointer `prev` to the previously processed node.
- While returning from recursion:
    1. Set current node's left child to NULL.
    2. Connect current node's right child to `prev`.
    3. Update `prev` to the current node.
- The final tree becomes a right-skewed linked list following preorder traversal.

Time Complexity: O(N)
Space Complexity: O(H)
(H = Height of the tree due to recursion stack)
*/

class Solution {
public:
    TreeNode* prev = NULL;

    void flatten(TreeNode* root) {
        if (root == NULL) {
            return;
        }

        flatten(root->right);
        flatten(root->left);

        root->left = NULL;
        root->right = prev;
        prev = root;
    }
};
