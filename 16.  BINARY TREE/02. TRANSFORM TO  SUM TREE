 // Transform to Sum Tree:
// In a Sum Tree, every node stores the sum of the values present in its left and right subtrees
// in the original tree. Leaf nodes become 0 since they do not have any children.

CODE

int solve(Node* root){
        if(root==NULL){
            return 0;
        }

        int left=solve(root->left);
        int right=solve(root->right);

        int temp=root->data;
        root->data +=left+right;

        return temp+left+right;
    }

    void toSumTree(Node* root){
        solve(root);
    }
};
